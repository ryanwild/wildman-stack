{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "lib": ["es2023"],
    "module": "nodenext",
    "moduleDetection": "force",
    "moduleResolution": "nodenext",
    "noEmit": true,
    "rootDir": "..",
    "rootDirs": ["src"],
    "skipLibCheck": true,
    "strict": true,
    "target": "es2023",
    "types": ["node"]
  }
}
